{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": [
    {
      "source": "website/backend",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        ".env",
        ".env.*",
        "firebase-service-account.json",
        "*.log"
      ]
    }
  ],
  "emulators": {
    "functions": { "port": 5001 },
    "database": { "port": 9000 },
    "ui": { "enabled": true }
  }
}
