# ── Local development ─────────────────────────────────────────────────────────

# Path to the Firebase service account JSON key file (downloaded from Firebase
# Console → Project Settings → Service Accounts → Generate new private key).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Firebase Realtime Database URL
DATABASE_URL=https://home-automation-a86aa-default-rtdb.firebaseio.com

# Email that should have admin privileges (must match a Firebase Auth account)
ADMIN_EMAIL=YOUR_FIREBASE_EMAIL

# Port the backend listens on locally
PORT=5000

# CORS origin for local frontend dev server
CORS_ORIGIN=http://localhost:5173

# ── Vercel / production ───────────────────────────────────────────────────────

# Service account JSON as a single-line string (Vercel env var).
# Paste the full contents of firebase-service-account.json here, minified.
# This is used instead of GOOGLE_APPLICATION_CREDENTIALS on Vercel.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase Web API key — used inside the generated .ino firmware so the ESP32
# can authenticate to Firebase. Found in Firebase Console → Project Settings →
# General → Your apps → Web app → apiKey.
FIREBASE_WEB_API_KEY=

# A dedicated Firebase Auth account for ESP32 devices to authenticate with.
# Create it in Firebase Console → Authentication → Users → Add user.
ESP32_DEVICE_EMAIL=esp32-device@yourdomain.com
ESP32_DEVICE_PASSWORD=
